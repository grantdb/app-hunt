{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "app-hunt",
  "post": {
    "dir": "webroot",
    "entrypoints": {
      "default": {
        "entry": "index.html",
        "height": "tall"
      }
    }
  },
  "permissions": {
    "redis": true,
    "reddit": true
  }
}
