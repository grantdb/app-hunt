{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "app-hunt",
  "post": {
    "dir": "webroot",
    "entrypoints": {
      "default": {
        "inline": true,
        "entry": "index.html"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.js"
  },
  "menu": {
    "items": [
      {
        "label": "Post app-hunt",
        "description": "Create a new app hunt post",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/post-create"
      }
    ]
  },
  "permissions": {
    "redis": true,
    "reddit": true
  }
}
